{
    "name": "goodagency/compressly",
    "description": "Lightweight WordPress image optimization powered by ShortPixel.",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "authors": [
        {
            "name": "GoodAgency",
            "homepage": "https://github.com/JafetGoodAgency"
        }
    ],
    "require": {
        "php": ">=7.4",
        "shortpixel/shortpixel-php": "^2.0",
        "yahnis-elsts/plugin-update-checker": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "GoodAgency\\Compressly\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
